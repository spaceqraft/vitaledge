{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vitaledge.dev/schema/explain-output/v1",
  "title": "VitalEdge EXPLAIN Output",
  "description": "Dry-run planning output for Cypher EXPLAIN.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "query",
    "summary",
    "logicalPlan",
    "physicalPlan",
    "influencers",
    "cardinality",
    "costEstimate",
    "runtimeStats",
    "indexDecisions",
    "warnings"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version for EXPLAIN output.",
      "const": "v1"
    },
    "query": {
      "$ref": "#/$defs/query"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "logicalPlan": {
      "$ref": "#/$defs/plan"
    },
    "physicalPlan": {
      "$ref": "#/$defs/plan"
    },
    "influencers": {
      "$ref": "#/$defs/influencers"
    },
    "cardinality": {
      "type": "array",
      "description": "Per-plan-vertex cardinality entries.",
      "items": {
        "$ref": "#/$defs/cardinalityEntry"
      }
    },
    "costEstimate": {
      "$ref": "#/$defs/costEstimate"
    },
    "runtimeStats": {
      "$ref": "#/$defs/runtimeStats"
    },
    "indexDecisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/indexDecision"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning"
      }
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "$defs": {
    "query": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text",
        "fingerprint",
        "statementKind",
        "tenant"
      ],
      "properties": {
        "text": {
          "type": "string"
        },
        "fingerprint": {
          "type": "string",
          "description": "Stable query-shape fingerprint suitable for grouping and comparisons."
        },
        "statementKind": {
          "type": "string"
        },
        "tenant": {
          "type": "string"
        },
        "params": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "options": {
          "$ref": "#/$defs/queryOptions"
        }
      }
    },
    "queryOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "projectionClauses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/queryProjectionClause"
          }
        },
        "distinct": {
          "type": "boolean"
        },
        "includeAll": {
          "type": "boolean"
        },
        "orderBy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skip": {
          "type": "string"
        },
        "limit": {
          "type": "string"
        }
      }
    },
    "queryProjectionClause": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "WITH",
            "RETURN"
          ]
        },
        "distinct": {
          "type": "boolean"
        },
        "includeAll": {
          "type": "boolean"
        },
        "projection": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "orderBy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skip": {
          "type": "string"
        },
        "limit": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dryRun",
        "readOnly",
        "writesDetected",
        "semanticPhaseStatus",
        "planningPhaseStatus"
      ],
      "properties": {
        "dryRun": {
          "type": "boolean",
          "const": true
        },
        "readOnly": {
          "type": "boolean"
        },
        "writesDetected": {
          "type": "boolean"
        },
        "semanticPhaseStatus": {
          "type": "string",
          "enum": [
            "ok",
            "error"
          ]
        },
        "planningPhaseStatus": {
          "type": "string",
          "enum": [
            "ok",
            "error"
          ]
        }
      }
    },
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootVertexId",
        "vertexes"
      ],
      "properties": {
        "rootVertexId": {
          "type": "string"
        },
        "vertexes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/planVertex"
          }
        }
      }
    },
    "planVertex": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "op",
        "children"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "op": {
          "type": "string"
        },
        "children": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "accessPath": {
          "type": "string"
        },
        "predicate": {
          "type": "string"
        },
        "projection": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ordering": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pagination": {
          "$ref": "#/$defs/pagination"
        },
        "writeAction": {
          "type": "string"
        }
      }
    },
    "pagination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skip": {
          "type": "string"
        },
        "limit": {
          "type": "string"
        }
      }
    },
    "influencers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vertexCounts",
        "edgeCounts",
        "predicateSignals",
        "statsSnapshot"
      ],
      "properties": {
        "vertexCounts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/vertexCount"
          }
        },
        "edgeCounts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/edgeCount"
          }
        },
        "predicateSignals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/predicateSignal"
          }
        },
        "statsSnapshot": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "capturedAt"
          ],
          "properties": {
            "source": {
              "type": "string",
              "description": "Source of statistics used by planning, for example runtime catalog, sampled probes, or static defaults."
            },
            "capturedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    },
    "vertexCount": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "count",
        "quality"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "quality": {
          "$ref": "#/$defs/quality"
        }
      }
    },
    "edgeCount": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "direction",
        "count",
        "quality"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "direction": {
          "type": "string",
          "enum": [
            "out",
            "in",
            "undirected"
          ]
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "quality": {
          "$ref": "#/$defs/quality"
        }
      }
    },
    "predicateSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expression",
        "matchedCount",
        "quality"
      ],
      "properties": {
        "expression": {
          "type": "string"
        },
        "matchedCount": {
          "type": "integer",
          "minimum": 0
        },
        "quality": {
          "$ref": "#/$defs/quality"
        }
      }
    },
    "cardinalityEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vertexId",
        "rowsIn",
        "rowsOut",
        "quality"
      ],
      "properties": {
        "vertexId": {
          "type": "string"
        },
        "rowsIn": {
          "type": "integer",
          "minimum": 0
        },
        "rowsOut": {
          "type": "integer",
          "minimum": 0
        },
        "quality": {
          "$ref": "#/$defs/quality"
        },
        "sampleSize": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "costEstimate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "value",
        "unit",
        "quality",
        "components"
      ],
      "properties": {
        "model": {
          "type": "string"
        },
        "value": {
          "type": "integer",
          "minimum": 1
        },
        "unit": {
          "type": "string",
          "const": "work_units"
        },
        "quality": {
          "$ref": "#/$defs/quality"
        },
        "components": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scanRows",
            "outputRows",
            "missingIndexPenalty"
          ],
          "properties": {
            "scanRows": {
              "type": "integer",
              "minimum": 0
            },
            "outputRows": {
              "type": "integer",
              "minimum": 0
            },
            "missingIndexPenalty": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "runtimeStats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "store",
        "plan",
        "index",
        "cardinality"
      ],
      "properties": {
        "store": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "verticesScanned",
            "edgesScanned"
          ],
          "properties": {
            "verticesScanned": {
              "type": "integer",
              "minimum": 0
            },
            "edgesScanned": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "plan": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "totalVertexes",
            "scanVertexes",
            "filterVertexes",
            "projectionVertexes",
            "sortVertexes",
            "paginationVertexes",
            "writeVertexes",
            "warningCount"
          ],
          "properties": {
            "totalVertexes": {
              "type": "integer",
              "minimum": 0
            },
            "scanVertexes": {
              "type": "integer",
              "minimum": 0
            },
            "filterVertexes": {
              "type": "integer",
              "minimum": 0
            },
            "projectionVertexes": {
              "type": "integer",
              "minimum": 0
            },
            "sortVertexes": {
              "type": "integer",
              "minimum": 0
            },
            "paginationVertexes": {
              "type": "integer",
              "minimum": 0
            },
            "writeVertexes": {
              "type": "integer",
              "minimum": 0
            },
            "warningCount": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "index": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "candidates",
            "selected",
            "missing"
          ],
          "properties": {
            "candidates": {
              "type": "integer",
              "minimum": 0
            },
            "selected": {
              "type": "integer",
              "minimum": 0
            },
            "missing": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "cardinality": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "rowsRead",
            "rowsOutput",
            "quality"
          ],
          "properties": {
            "rowsRead": {
              "type": "integer",
              "minimum": 0
            },
            "rowsOutput": {
              "type": "integer",
              "minimum": 0
            },
            "quality": {
              "$ref": "#/$defs/quality"
            }
          }
        }
      }
    },
    "indexDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vertexId",
        "schema",
        "property",
        "candidate",
        "selected",
        "reason"
      ],
      "properties": {
        "vertexId": {
          "type": "string"
        },
        "schema": {
          "type": "string"
        },
        "property": {
          "type": "string"
        },
        "candidate": {
          "type": "boolean"
        },
        "selected": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "estimatedSelectivity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "accessPath": {
          "type": "string"
        },
        "recommendation": {
          "type": "string",
          "enum": [
            "keep-index",
            "create-index",
            "consider-index",
            "optional-index"
          ]
        },
        "tuningImpact": {
          "type": "string",
          "enum": [
            "none",
            "high",
            "medium",
            "low"
          ]
        },
        "scanPopulation": {
          "type": "integer",
          "minimum": 0
        },
        "matchedCount": {
          "type": "integer",
          "minimum": 0
        },
        "estimatedRowsSaved": {
          "type": "integer",
          "minimum": 0
        },
        "quality": {
          "$ref": "#/$defs/quality"
        },
        "suggestedIndex": {
          "type": "string"
        }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "vertexId": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "engineVersion": {
          "type": "string"
        },
        "transport": {
          "type": "string",
          "description": "Current serialization transport for this output; JSON is used for rapid iteration before protobuf/gRPC mapping."
        }
      }
    },
    "quality": {
      "type": "string",
      "enum": [
        "exact",
        "estimate",
        "sample"
      ]
    }
  }
}
