{
  "title": "VitalEdge Overview",
  "uid": "vitaledge-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Statement Throughput (1m)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(vitaledge_executor_statements_total[1m])) by (kind, outcome)",
          "legendFormat": "{{kind}} {{outcome}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Statement Duration Percentiles (ms, 5m)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.50, sum(rate(vitaledge_executor_statement_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "1000 * histogram_quantile(0.95, sum(rate(vitaledge_executor_statement_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "1000 * histogram_quantile(0.99, sum(rate(vitaledge_executor_statement_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "id": 3,
      "title": "Rows Returned (1m rate)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(vitaledge_executor_rows_returned_total[1m])",
          "legendFormat": "rows/s"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "id": 4,
      "title": "Index Lookup Outcomes (5m)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(vitaledge_executor_index_lookups_total[5m])) by (strategy, outcome)",
          "legendFormat": "{{strategy}} {{outcome}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    },
    {
      "id": 5,
      "title": "Top Unindexed Candidates",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "topk(10, vitaledge_executor_unindexed_candidate_observations)",
          "format": "table",
          "instant": true
        }
      ],
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 16}
    },
    {
      "id": 6,
      "title": "Host CPU Usage (%)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "100 * (1 - (rate(vitaledge_host_cpu_seconds_total{mode=\"idle\"}[5m]) / clamp_min(sum(rate(vitaledge_host_cpu_seconds_total[5m])), 1e-9)))",
          "legendFormat": "cpu"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25}
    },
    {
      "id": 7,
      "title": "Host Memory Usage (%)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "100 * (1 - (vitaledge_host_memory_available_bytes / clamp_min(vitaledge_host_memory_total_bytes, 1)))",
          "legendFormat": "memory"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 25}
    },
    {
      "id": 8,
      "title": "Host Network Throughput (bytes/s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(vitaledge_host_network_receive_bytes_total[1m])",
          "legendFormat": "rx"
        },
        {
          "expr": "rate(vitaledge_host_network_transmit_bytes_total[1m])",
          "legendFormat": "tx"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 33}
    },
    {
      "id": 9,
      "title": "Go Goroutines",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "vitaledge_go_goroutines",
          "legendFormat": "goroutines"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 33}
    },
    {
      "id": 10,
      "title": "Go GC Pause (ms/s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "1000 * rate(vitaledge_go_gc_pause_seconds_total[5m])",
          "legendFormat": "gc pause"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 41}
    },
    {
      "id": 11,
      "title": "Go Heap Allocated (bytes)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "vitaledge_go_memory_heap_alloc_bytes",
          "legendFormat": "heap alloc"
        },
        {
          "expr": "vitaledge_go_next_gc_heap_target_bytes",
          "legendFormat": "next gc target"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 41}
    },
    {
      "id": 12,
      "title": "Statement Duration Percentiles by Kind (ms, 5m)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.50, sum(rate(vitaledge_executor_statement_duration_seconds_bucket[5m])) by (le, kind))",
          "legendFormat": "p50 {{kind}}"
        },
        {
          "expr": "1000 * histogram_quantile(0.95, sum(rate(vitaledge_executor_statement_duration_seconds_bucket[5m])) by (le, kind))",
          "legendFormat": "p95 {{kind}}"
        },
        {
          "expr": "1000 * histogram_quantile(0.99, sum(rate(vitaledge_executor_statement_duration_seconds_bucket[5m])) by (le, kind))",
          "legendFormat": "p99 {{kind}}"
        }
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 49}
    }
  ]
}
